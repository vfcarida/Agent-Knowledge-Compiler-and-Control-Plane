{
  "name": "@ocf/core",
  "version": "0.1.0",
  "private": true,
  "description": "OKF (Open Knowledge Format) engine for career data management. Domain layer with file-based repository, frontmatter parsing, and document lifecycle services.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.2.0"
  }
}
