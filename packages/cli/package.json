{
  "name": "@ocf/cli",
  "version": "0.1.0",
  "private": true,
  "description": "AKCP CLI: Generate, validate, update, and publish akcp context packs.",
  "type": "module",
  "bin": {
    "akcp": "./dist/index.js",
    "agent-ready": "./dist/legacy-bin.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "node -e \"fs.rmSync('dist', {recursive:true,force:true}); fs.rmSync('*.tsbuildinfo', {force:true})\""
  },
  "dependencies": {
    "@ocf/core": "workspace:*",
    "@ocf/conformance": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
